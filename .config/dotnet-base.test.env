INT_COVERAGE_EXCLUDE=[*]*.Program
INT_COVERAGE_INCLUDE=[App]*
INT_COVERAGE_MIN=80
INT_COVERAGE_OUTPUT=TestResults/int/coverage
INT_TEST_RESULTS=TestResults/int
TEST_COVERAGE_FORMAT=cobertura
UNIT_COVERAGE_EXCLUDE=[*]*.Program
UNIT_COVERAGE_INCLUDE=[Lib]*
UNIT_COVERAGE_MIN=100
UNIT_COVERAGE_OUTPUT=TestResults/unit/coverage
UNIT_TEST_RESULTS=TestResults/unit
